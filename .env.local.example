# Skin & Vision Clinic — Environment Variables
# Copy this file to .env.local and fill in real values before deploying.

# Convex backend (run `npx convex dev` to get this URL)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Google Tag Manager (format: GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=

# Google Analytics Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID
NEXT_PUBLIC_META_PIXEL_ID=

# Site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://skinandvision.nl

# ClinicMinds booking URL (do not change)
NEXT_PUBLIC_BOOKING_URL=https://schedule.clinicminds.com/?clinic=636e9065-78db-11f0-953e-0667c42d6c5b&hide-logo

# ZorgkaartNederland URL (do not change)
NEXT_PUBLIC_ZORGKAART_URL=https://www.zorgkaartnederland.nl/zorgverlener/oogarts-kloos-r-j-h-m-126894

# Resend API key — used for contact form notifications and newsletter welcome emails
# Get yours at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
